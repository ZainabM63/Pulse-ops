{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader --no-interaction",
  "outputDirectory": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
